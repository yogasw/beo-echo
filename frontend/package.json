{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "PORT=3005 node build",
    "dev": "vite dev --host 0.0.0.0 --port 3005",
    "build": "vite build",
    "build:desktop": "VITE_DESKTOP_MODE=true vite build",
    "build:landing-page": "VITE_LANDING_MODE=true vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "static-web-test": "npm run build && npx serve -s build -l 3005",
    "test": "vitest",
    "vitest": "vitest"
  },
  "devDependencies": {
    "@neoconfetti/svelte": "^2.0.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.53.7",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.0.0",
    "vite": "^6.3.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "axios": "^1.13.6",
    "isomorphic-dompurify": "^3.0.0",
    "marked": "^17.0.4"
  }
}
